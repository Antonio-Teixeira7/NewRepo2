@page "/users"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject UserApiClient UserApiClient
@inject UserSessionService UserSessionService

<PageTitle>Usuários</PageTitle>

<section class="users-shell">
    <div class="users-hero">
        <div>
            <span class="users-kicker">Área autenticada</span>
            <h1>Usuários cadastrados</h1>
            <p>Depois do login, esta tela exibe todos os usuários criados no microsserviço `UserSite`.</p>
        </div>

        <div class="users-session-card">
            <span>Sessão ativa</span>
            <strong>@(string.IsNullOrWhiteSpace(UserSessionService.Email) ? "Usuário autenticado" : UserSessionService.Email)</strong>
            <button class="btn users-logout" @onclick="Logout">Sair</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="users-alert users-alert-error">@errorMessage</div>
    }

    <div class="users-summary-grid">
        <div class="users-summary-card">
            <span>Total</span>
            <strong>@users.Count</strong>
        </div>
        <div class="users-summary-card">
            <span>Ativos</span>
            <strong>@users.Count(user => user.IsActive)</strong>
        </div>
        <div class="users-summary-card">
            <span>Inativos</span>
            <strong>@users.Count(user => !user.IsActive)</strong>
        </div>
    </div>

    <div class="users-card">
        <div class="users-card-header">
            <div>
                <h2>Lista completa</h2>
                <p>Dados protegidos por autenticação JWT emitida pelo `AuthService`.</p>
            </div>
            <button class="btn users-refresh" @onclick="LoadUsersAsync" disabled="@isLoading">
                @(isLoading ? "Carregando..." : "Atualizar")
            </button>
        </div>

        @if (!isPageReady || isLoading)
        {
            <div class="users-empty-state">Carregando usuários...</div>
        }
        else if (users.Count == 0)
        {
            <div class="users-empty-state">Nenhum usuário cadastrado foi encontrado.</div>
        }
        else
        {
            <div class="users-table-wrapper">
                <table class="table users-table align-middle">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Nome</th>
                            <th>Email</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in users)
                        {
                            <tr>
                                <td>@user.Id</td>
                                <td>@user.Name</td>
                                <td>@user.Email</td>
                                <td>
                                    <span class="users-status @(user.IsActive ? "status-active" : "status-inactive")">
                                        @(user.IsActive ? "Ativo" : "Inativo")
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

@code {
    private readonly List<UserDto> users = [];
    private bool isPageReady;
    private bool isLoading;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await UserSessionService.RestoreAsync();

        if (!UserSessionService.IsAuthenticated)
        {
            Navigation.NavigateTo("/");
            return;
        }

        await LoadUsersAsync();
        isPageReady = true;
        StateHasChanged();
    }

    private async Task LoadUsersAsync()
    {
        if (!UserSessionService.IsAuthenticated)
        {
            Navigation.NavigateTo("/");
            return;
        }

        errorMessage = null;
        isLoading = true;

        try
        {
            var result = await UserApiClient.GetAllAsync();
            users.Clear();
            users.AddRange(result);
        }
        catch (Exception ex)
        {
            errorMessage = $"Não foi possível carregar os usuários: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Logout()
    {
        await UserSessionService.ClearAsync();
        Navigation.NavigateTo("/");
    }
}
