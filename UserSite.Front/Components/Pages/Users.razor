@page "/users"
@rendermode InteractiveServer
@inject UserApiClient UserApiClient

<PageTitle>Users</PageTitle>

<h1>Gerenciar usuários</h1>

<p>Use esta tela para criar, consultar, atualizar, ativar e desativar usuários.</p>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h4 mb-3">@(isEditMode ? "Atualizar usuário" : "Criar usuário")</h2>

                @if (isEditMode)
                {
                    <div class="mb-3">
                        <label class="form-label">Id</label>
                        <input class="form-control" value="@formModel.Id" disabled />
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label">Nome</label>
                    <input class="form-control" @bind="formModel.Name" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input class="form-control" @bind="formModel.Email" />
                </div>

                <div class="mb-3">
                    <label class="form-label">@(isEditMode ? "Nova senha (opcional)" : "Senha")</label>
                    <input class="form-control" type="password" @bind="password" autocomplete="new-password" />
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@isSaving">
                        @(isSaving ? "Salvando..." : isEditMode ? "Atualizar" : "Criar")
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="ResetForm">Limpar</button>
                    <button class="btn btn-outline-dark" @onclick="() => RefreshAsync()" disabled="@isLoading">Recarregar</button>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mt-4">
            <div class="card-body">
                <h2 class="h4 mb-3">Buscar por nome</h2>

                <div class="input-group">
                    <input class="form-control" placeholder="Digite o nome" @bind="searchName" />
                    <button class="btn btn-outline-primary" @onclick="SearchAsync">Buscar</button>
                </div>

                @if (searchedUser is not null)
                {
                    <div class="mt-3 border rounded p-3 bg-light">
                        <div><strong>Id:</strong> @searchedUser.Id</div>
                        <div><strong>Nome:</strong> @searchedUser.Name</div>
                        <div><strong>Email:</strong> @searchedUser.Email</div>
                        <div><strong>Status:</strong> @(searchedUser.IsActive ? "Ativo" : "Inativo")</div>
                        <div class="mt-3 d-flex gap-2">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEdit(searchedUser)">Editar</button>
                            <button class="btn btn-sm @(searchedUser.IsActive ? "btn-outline-warning" : "btn-outline-success")" @onclick="() => ToggleStatusAsync(searchedUser)">
                                @(searchedUser.IsActive ? "Desativar" : "Ativar")
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h4 mb-0">Usuários cadastrados</h2>
                    <span class="badge text-bg-secondary">@users.Count</span>
                </div>

                @if (isLoading)
                {
                    <p><em>Carregando usuários...</em></p>
                }
                else if (users.Count == 0)
                {
                    <p>Nenhum usuário encontrado.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Id</th>
                                    <th>Nome</th>
                                    <th>Email</th>
                                    <th>Status</th>
                                    <th class="text-end">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in users)
                                {
                                    <tr>
                                        <td>@user.Id</td>
                                        <td>@user.Name</td>
                                        <td>@user.Email</td>
                                        <td>
                                            <span class="badge @(user.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                                @(user.IsActive ? "Ativo" : "Inativo")
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <div class="btn-group">
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEdit(user)">Editar</button>
                                                <button class="btn btn-sm @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")" @onclick="() => ToggleStatusAsync(user)">
                                                    @(user.IsActive ? "Desativar" : "Ativar")
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private readonly List<UserDto> users = [];
    private UserDto formModel = new();
    private UserDto? searchedUser;
    private string password = string.Empty;
    private string searchName = string.Empty;
    private string? errorMessage;
    private string? successMessage;
    private bool isEditMode;
    private bool isLoading;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync(bool clearMessages = true)
    {
        if (clearMessages)
        {
            ClearMessages();
        }

        isLoading = true;

        try
        {
            var result = await UserApiClient.GetAllAsync();
            users.Clear();
            users.AddRange(result);

            if (searchedUser is not null)
            {
                searchedUser = users.FirstOrDefault(u => u.Id == searchedUser.Id);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar usuários: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        ClearMessages();

        if (string.IsNullOrWhiteSpace(formModel.Name) || string.IsNullOrWhiteSpace(formModel.Email))
        {
            errorMessage = "Nome e email são obrigatórios.";
            return;
        }

        if (!isEditMode && string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Senha é obrigatória na criação.";
            return;
        }

        isSaving = true;

        try
        {
            var successText = isEditMode
                ? "Usuário atualizado com sucesso."
                : "Usuário criado com sucesso.";

            if (isEditMode)
            {
                await UserApiClient.UpdateAsync(formModel.Id, new UpdateUserRequest
                {
                    Name = formModel.Name,
                    Email = formModel.Email,
                    Password = string.IsNullOrWhiteSpace(password) ? null : password
                });
            }
            else
            {
                await UserApiClient.CreateAsync(new CreateUserRequest
                {
                    Name = formModel.Name,
                    Email = formModel.Email,
                    Password = password
                });
            }

            ResetForm();
            await RefreshAsync(false);
            successMessage = successText;
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao salvar usuário: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SearchAsync()
    {
        ClearMessages();

        if (string.IsNullOrWhiteSpace(searchName))
        {
            errorMessage = "Informe um nome para pesquisar.";
            return;
        }

        try
        {
            searchedUser = await UserApiClient.GetByNameAsync(searchName.Trim());
            successMessage = "Usuário encontrado.";
        }
        catch (Exception ex)
        {
            searchedUser = null;
            errorMessage = $"Erro ao buscar usuário: {ex.Message}";
        }
    }

    private void StartEdit(UserDto user)
    {
        ClearMessages();
        isEditMode = true;
        password = string.Empty;
        formModel = new UserDto
        {
            Id = user.Id,
            Name = user.Name,
            Email = user.Email,
            IsActive = user.IsActive
        };
    }

    private async Task ToggleStatusAsync(UserDto user)
    {
        ClearMessages();

        try
        {
            var successText = user.IsActive
                ? "Usuário desativado com sucesso."
                : "Usuário ativado com sucesso.";

            if (user.IsActive)
            {
                await UserApiClient.DeactivateAsync(user.Id);
            }
            else
            {
                await UserApiClient.ActivateAsync(user.Id);
            }

            await RefreshAsync(false);
            successMessage = successText;
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao alterar status do usuário: {ex.Message}";
        }
    }

    private void ResetForm()
    {
        isEditMode = false;
        formModel = new UserDto();
        password = string.Empty;
    }

    private void ClearMessages()
    {
        errorMessage = null;
        successMessage = null;
    }
}
